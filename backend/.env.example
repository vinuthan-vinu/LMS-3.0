# Required
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/lms
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars

# Server
# If port 5000 is "in use" on macOS, turn off System Settings → AirPlay Receiver, or use PORT=5051
# (and set mobile/.env EXPO_PUBLIC_API_URL=http://localhost:5051 to match).
PORT=5000
NODE_ENV=development

# Optional — production CORS (comma-separated; use * only for quick tests)
# ALLOWED_ORIGINS=https://your-app.expo.app,https://your-domain.com

# Optional — throttle auth (defaults: 60 req / 15 min per IP)
# AUTH_RATE_LIMIT_MAX=60
# CHAT_RATE_LIMIT_MAX=40

# Optional — Cloudinary (recommended on Railway/Render for durable file URLs)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# JWT lifetime (User model fallback is 7d if unset)
# JWT_EXPIRE=7d

# Gemini AI Configuration
GEMINI_API_KEY=
