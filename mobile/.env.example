# Copy to .env in this folder (optional). Overrides app.json extra.apiUrl.
# Must match backend PORT in backend/.env (default 5000 in server.js and .env.example).
#
# macOS: AirPlay Receiver sometimes uses port 5000 — if the API won't start, use e.g. PORT=5051
# in backend/.env and set the same port here:
# EXPO_PUBLIC_API_URL=http://localhost:5051

EXPO_PUBLIC_API_URL=http://localhost:5000
