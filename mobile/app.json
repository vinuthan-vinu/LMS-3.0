{
  "expo": {
    "name": "Academic Excellence LMS",
    "slug": "academic-excellence-lms",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/login-hero.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/login-hero.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*.png",
      "**/*.jpg",
      "**/*.jpeg"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/login-hero.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "outdir": "web-build"
    },
    "extra": {
      "apiUrl": "http://localhost:5051/api"
    }
  }
}
